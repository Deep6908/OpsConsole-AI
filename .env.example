# =============================================================================
# IT Helpdesk Automation System — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to source control.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# Set to 'production' to disable the /api/v1/auth/demo-token endpoint
NODE_ENV=development

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ── Microsoft SQL Server ──────────────────────────────────────────────────────
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASSWORD=
MSSQL_DATABASE=helpdesk_db
# Set to 'true' if your SQL Server uses an SSL certificate (Azure SQL always requires it)
MSSQL_ENCRYPT=false
# Set to 'true' only for self-signed / dev certificates
MSSQL_TRUST_SERVER_CERT=true

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local: mongodb://localhost:27017/helpdesk_logs
# Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/helpdesk_logs
MONGO_URI=mongodb://localhost:27017/helpdesk_logs

# ── Email / Escalation ────────────────────────────────────────────────────────
# The address that receives escalation alert emails
ESCALATION_EMAIL=it-escalations@company.com

# SMTP credentials (e.g. Mailtrap for dev, SendGrid / SES for prod)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Display name shown in From field
SMTP_FROM_NAME=IT Helpdesk Bot
SMTP_FROM_EMAIL=helpdesk-bot@company.com
